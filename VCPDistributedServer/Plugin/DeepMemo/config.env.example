# DeepMemo configuration example
# Copy this file to config.env and adjust the values for your checkout.

# Local data root for Vchat. Prefer the canonical runtime root placeholder.
VchatDataURL=<runtime>

# Maximum tokens used for memo output.
MaxMemoTokens=60000

# Optional rerank settings.
RerankSearch=True
RerankUrl=http://localhost:8000/
RerankApi=your-rerank-api-key
RerankModel=Qwen/Qwen3-Reranker-8B
RerankMaxTokensPerBatch=30000
RerankTopN=5

# Optional default query preset.
QueryPreset=
