# PTYShellExecutor Plugin Configuration Template
# Copy this file to config.env and adjust local shell policy.

# Return mode for synchronous execution: delta or full.
SHELL_RETURN_MODE=delta

# Comma-separated shell preference order.
SHELL_PRIORITY=pwsh,powershell,cmd,bash,sh

# Commands that should always be blocked.
# Set to an empty value (FORBIDDEN_COMMANDS=) to clear the built-in defaults
# and disable all command blocking. Use with caution.
FORBIDDEN_COMMANDS=rm -rf,dd if=,mkfs,fdisk,shutdown,reboot,poweroff,halt

# Commands that require explicit confirmation before execution.
# Set to an empty value (AUTH_REQUIRED_COMMANDS=) to clear the built-in defaults
# and disable all confirmation prompts. Use with caution.
AUTH_REQUIRED_COMMANDS=rm ,mv ,chmod ,chown ,systemctl ,service ,docker ,kubectl ,git push,git reset,kill ,killall ,pkill

# Timeout for synchronous command execution in milliseconds.
COMMAND_TIMEOUT=60000

# PTY mode: auto, pty, or pipe.
PTY_MODE=auto
