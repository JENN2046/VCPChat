gitignore

# 不忽略 .gitignore 文件本身（这是Git的常见实践）
!.gitignore

AppData/

node_modules/

.env
!audio_engine/.env

# Local runtime configuration files must stay out of Git.
**/.env
**/config.env
**/config.local.env
!**/.env.example
!**/config.env.example

/public/assets

**/.DS_Store

# Rust build artifacts
**/target/
**/Cargo.lock
rust_audio_engine/.cargo/

# Reports and logs
**/reports/

# 临时忽略的文件（本地修改，不提交）
.npmrc
modules/ipc/chatHandlers.js
modules/itemListManager.js
modules/settingsManager.js
package-lock.json
package.json
styles/themes.css

# LibreHardwareMonitor 官方二进制由开发者本地自行准备，不进入仓库
vendor/LibreHardwareMonitor/*
!vendor/LibreHardwareMonitor/README.md
VCPDistributedServer/Plugin/DistImageServer/config.env
VCPDistributedServer/Plugin/FileOperator/.env

# 忽略 WebIndexTTS2 生成输出目录
/WebIndexTTS2/tmp-output/

# VCPChat local runtime and generated artifacts
.claude/
.omc/
Desktopmodules/.omc/
dist/
AppData/
config.json
loudness_cache.db
NativeSplash.exe
**/*.bak
**/*.log
**/reports/
VCPDistributedServer/Plugin/*/.env
VCPDistributedServer/Plugin/*/config.env
VCPDistributedServer/Plugin/*/config.local.env
