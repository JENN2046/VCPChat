# FileOperator plugin configuration example
# Copy this file to .env and adjust the values for your checkout.

# Allowed directories for file operations.
# Use repo-relative or workspace-relative paths. Keep the list explicit.
ALLOWED_DIRECTORIES=<workspace>/dailynote,<workspace>/AppData/Canvas,<workspace>/VCPChat

# Default download directory for DownloadFile operations.
DEFAULT_DOWNLOAD_DIR=<workspace>/Downloads

# Maximum file size for operations (in bytes).
MAX_FILE_SIZE=10485760

# Maximum number of files returned in directory listings.
MAX_DIRECTORY_ITEMS=1000

# Maximum number of search results.
MAX_SEARCH_RESULTS=100

# Enable debug logging.
DEBUG_MODE=true

# WebSocket settings for push notifications.
WEBSOCKET_HOST=localhost
WEBSOCKET_PORT=6573

# File operation settings.
ENABLE_RECURSIVE_OPERATIONS=true
ENABLE_HIDDEN_FILES=false

# Backup settings.
CREATE_BACKUPS=false
BACKUP_DIRECTORY=<workspace>/backups/FileOperator

# Additional security options
# REQUIRE_CONFIRMATION=false  # Require confirmation for destructive operations
# LOG_ALL_OPERATIONS=true     # Log all file operations to a file
