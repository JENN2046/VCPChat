# PowerShellExecutor Plugin Configuration Template
# Copy this file to config.env and adjust local command policy.

# Return mode for synchronous execution: delta or full.
POWERSHELL_RETURN_MODE=delta

# Cmdlets or command fragments that should always be blocked.
# Set to an empty value (FORBIDDEN_COMMANDS=) to clear the built-in defaults
# and disable all command blocking. Use with caution.
FORBIDDEN_COMMANDS=clear-disk,format-volume,stop-computer,restart-computer,remove-item -recurse,remove-item -force,diskpart,bcdedit

# Cmdlets or command fragments that require explicit confirmation.
# Set to an empty value (AUTH_REQUIRED_COMMANDS=) to clear the built-in defaults
# and disable all confirmation prompts. Use with caution.
AUTH_REQUIRED_COMMANDS=remove-item,stop-process,restart-service,set-service,start-process,invoke-expression,taskkill,reg add,reg delete,git push,git reset
